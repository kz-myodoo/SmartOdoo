<?xml version="1.0" encoding="utf-8"?>
<interface version="1.4">
  <object class="ttk.Frame" id="mainframe">
    <layout manager="grid">
      <property name="row">0</property>
      <property name="column">0</property>
      <property name="sticky">nsew</property>
    </layout>

    <child>
      <object class="ttk.Frame" id="header">
        <property name="padding">12</property>
        <layout manager="grid">
          <property name="row">0</property>
          <property name="column">0</property>
          <property name="sticky">ew</property>
        </layout>
        <child>
          <object class="ttk.Label" id="title_label">
            <property name="text">SmartOdoo: GUI</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
            </layout>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="ttk.Labelframe" id="form">
        <property name="text">Parameters</property>
        <property name="padding">12</property>
        <layout manager="grid">
          <property name="row">1</property>
          <property name="column">0</property>
          <property name="sticky">nsew</property>
          <property name="padx">12</property>
        </layout>

        <child>
          <object class="ttk.Label" id="action_label">
            <property name="text">Action</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="action_combo">
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="odoo_label">
            <property name="text">Odoo version</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">2</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="odoo_combo">
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">3</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="project_name_label">
            <property name="text">Project name</property>
            <layout manager="grid">
              <property name="row">1</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="project_name_entry">
            <layout manager="grid">
              <property name="row">1</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="psql_label">
            <property name="text">Postgres version</property>
            <layout manager="grid">
              <property name="row">1</property>
              <property name="column">2</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="psql_combo">
            <layout manager="grid">
              <property name="row">1</property>
              <property name="column">3</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="addons_label">
            <property name="text">Addons URL</property>
            <layout manager="grid">
              <property name="row">2</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="addons_entry">
            <layout manager="grid">
              <property name="row">2</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="branch_label">
            <property name="text">Addons branch</property>
            <layout manager="grid">
              <property name="row">2</property>
              <property name="column">2</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="branch_combo">
            <layout manager="grid">
              <property name="row">2</property>
              <property name="column">3</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Checkbutton" id="enterprise_check">
            <property name="text">Enterprise</property>
            <layout manager="grid">
              <property name="row">3</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Checkbutton" id="upgrade_check">
            <property name="text">Upgrade mode</property>
            <layout manager="grid">
              <property name="row">3</property>
              <property name="column">1</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="db_label">
            <property name="text">DB</property>
            <layout manager="grid">
              <property name="row">4</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="db_entry">
            <layout manager="grid">
              <property name="row">4</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="module_label">
            <property name="text">Module</property>
            <layout manager="grid">
              <property name="row">4</property>
              <property name="column">2</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="module_entry">
            <layout manager="grid">
              <property name="row">4</property>
              <property name="column">3</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="tags_label">
            <property name="text">Tags</property>
            <layout manager="grid">
              <property name="row">5</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="tags_entry">
            <layout manager="grid">
              <property name="row">5</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="rebuild_label">
            <property name="text">Container to rebuild</property>
            <layout manager="grid">
              <property name="row">5</property>
              <property name="column">2</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Combobox" id="rebuild_combo">
            <layout manager="grid">
              <property name="row">5</property>
              <property name="column">3</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Label" id="pip_label">
            <property name="text">Pip package</property>
            <layout manager="grid">
              <property name="row">6</property>
              <property name="column">0</property>
              <property name="sticky">w</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="pip_entry">
            <layout manager="grid">
              <property name="row">6</property>
              <property name="column">1</property>
              <property name="sticky">ew</property>
              <property name="padx">4</property>
              <property name="pady">4</property>
            </layout>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="ttk.Frame" id="actions">
        <property name="padding">12 8 12 8</property>
        <layout manager="grid">
          <property name="row">2</property>
          <property name="column">0</property>
          <property name="sticky">ew</property>
        </layout>

        <child>
          <object class="ttk.Label" id="command_preview_label">
            <property name="text">Command:</property>
            <property name="anchor">w</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">0</property>
              <property name="sticky">ew</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="ttk.Frame" id="buttons">
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">1</property>
              <property name="sticky">e</property>
            </layout>

            <child>
              <object class="ttk.Button" id="run_btn">
                <property name="text">Run</property>
                <layout manager="grid">
                  <property name="row">0</property>
                  <property name="column">0</property>
                  <property name="padx">4</property>
                  <property name="pady">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="copy_btn">
                <property name="text">Copy command</property>
                <layout manager="grid">
                  <property name="row">0</property>
                  <property name="column">1</property>
                  <property name="padx">4</property>
                  <property name="pady">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="clear_btn">
                <property name="text">Clear logs</property>
                <layout manager="grid">
                  <property name="row">1</property>
                  <property name="column">0</property>
                  <property name="padx">4</property>
                  <property name="pady">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="copy_logs_btn">
                <property name="text">Copy logs</property>
                <layout manager="grid">
                  <property name="row">1</property>
                  <property name="column">1</property>
                  <property name="padx">4</property>
                  <property name="pady">2</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="ttk.Labelframe" id="output_frame">
        <property name="text">Logs</property>
        <property name="padding">8</property>
        <layout manager="grid">
          <property name="row">3</property>
          <property name="column">0</property>
          <property name="sticky">nsew</property>
          <property name="padx">12</property>
          <property name="pady">0 12</property>
        </layout>

        <child>
          <object class="tk.Text" id="output_text">
            <property name="wrap">word</property>
            <property name="height">18</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">0</property>
              <property name="sticky">nsew</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Scrollbar" id="logs_scroll">
            <property name="orient">vertical</property>
            <layout manager="grid">
              <property name="row">0</property>
              <property name="column">1</property>
              <property name="sticky">ns</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
