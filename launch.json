{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Odoo",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5858
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/addons",
                    "remoteRoot": "/mnt/extra-addons"
                },
                {
                    "localRoot": "<odoo_addons_location>",
                    "remoteRoot": "/usr/lib/python3/dist-packages/odoo/addons"
                }
            ],
            "logToFile": true,
            "justMyCode": false,
        },
    ]
}